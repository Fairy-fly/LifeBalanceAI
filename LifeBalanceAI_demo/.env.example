# Local development example. Copy to .env locally if needed.
# Never commit real keys.
# Android debug APKs do not bundle .env.
# For Android device tests, set DEEPSEEK_API_KEY in a local .env outside git,
# then run: powershell -File tools/android_push_env.ps1 -EnvFile .env
# The script writes .env into the app private config directory via adb run-as,
# then you must restart the app.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
LIFEBALANCE_THEME=light
